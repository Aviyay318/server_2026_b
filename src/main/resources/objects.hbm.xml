<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>


    <class name="server_2026_b.server.entities.User" table="users">
        <id name="id" column="id" type="long">
            <generator class="identity"/>
        </id>
        <property name="personalId" column="personal_id" type="string" length="9" not-null="true" unique="true"/>
        <property name="firstName" column="first_name" type="string"/>
        <property name="lastName" column="last_name" type="string"/>
        <property name="password" column="password" type="string" not-null="true"/>
        <property name="phone" column="phone" type="string"/>
        <property name="email" column="email" type="string"/>

        <property name="userType" column="user_type" not-null="true">
            <type name="org.hibernate.type.EnumType">
                <param name="enumClass">server_2026_b.server.utils.UserType</param>
                <param name="useNamed">true</param>
            </type>
        </property>
    </class>


    <class name="server_2026_b.server.entities.relations.EmploymentRelation"
           table="employment_relations">
        <id name="id" column="id" type="long">
            <generator class="identity"/>
        </id>
        <many-to-one name="employer"
                     class="server_2026_b.server.entities.User"
                     column="employer_id"
                     not-null="true"
                     unique-key="uk_employer_employee"/>

        <many-to-one name="employee"
                     class="server_2026_b.server.entities.User"
                     column="employee_id"
                     not-null="true"
                     unique-key="uk_employer_employee"/>
    </class>


    <class name="server_2026_b.server.entities.RefreshToken" table="refresh_token">
        <id name="id" column="id" type="java.lang.Long">
            <generator class="identity"/>
        </id>
        <property name="token" column="token" type="string" not-null="true" unique="true"/>
        <property name="userId" column="user_id" type="java.lang.Long" not-null="true" unique="true"/>
        <property name="userType" column="user_type" not-null="true">
            <type name="org.hibernate.type.EnumType">
                <param name="enumClass">server_2026_b.server.utils.UserType</param>
                <param name="useNamed">true</param>
            </type>
        </property>
        <property name="createdAt" column="created_at" type="java.time.LocalDateTime" not-null="true"/>
        <property name="expiresAt" column="expires_at" type="java.time.LocalDateTime" not-null="true"/>
    </class>


    <class name="server_2026_b.server.entities.WorkingSite" table="working_sites">
        <id name="id" column="id" type="long">
            <generator class="identity"/>
        </id>
        <property name="name" column="name" type="string" not-null="true"/>
        <property name="address" column="address" type="string"/>
        <property name="longitude" column="longitude" type="double"/>
        <property name="latitude" column="latitude" type="double"/>
    </class>

    <class name="server_2026_b.server.entities.WorkDay" table="work_day">
        <id name="id" column="id" type="java.lang.Long">
            <generator class="identity"/>
        </id>
        <property name="userId" column="user_id" type="java.lang.Long" not-null="true"/>
        <property name="enterTime" column="enter_time" type="timestamp"/>
        <property name="exitTime" column="exit_time" type="timestamp"/>
        <property name="enterLocation" column="enter_location" type="string"/>
        <property name="exitLocation" column="exit_location" type="string"/>
        <many-to-one name="enterSite"
                     class="server_2026_b.server.entities.WorkingSite"
                     column="enter_site_id"
                     not-null="false" />
        <many-to-one name="exitSite"
                     class="server_2026_b.server.entities.WorkingSite"
                     column="exit_site_id"/>

        <property name="status" column="status">
            <type name="org.hibernate.type.EnumType">
                <param name="enumClass">server_2026_b.server.utils.ShiftStatus</param>
                <param name="useNamed">true</param>
            </type>
        </property>
        <property name="absenceReason" column="absence_reason">
            <type name="org.hibernate.type.EnumType">
                <param name="enumClass">server_2026_b.server.utils.AbsenceReason</param>
                <param name="useNamed">true</param>
            </type>
        </property>
    </class>

    <class name="server_2026_b.server.entities.ArchivedEmployee" table="archived_employees">
        <id name="id" column="id" type="long">
            <generator class="identity"/>
        </id>
        <property name="personalId"          column="personal_id"            type="string" length="9" not-null="true"/>
        <property name="firstName"           column="first_name"             type="string"/>
        <property name="lastName"            column="last_name"              type="string"/>
        <property name="password"            column="password"               type="string"/>
        <property name="phone"               column="phone"                  type="string"/>
        <property name="email"               column="email"                  type="string"/>
        <property name="userType"            column="user_type">
            <type name="org.hibernate.type.EnumType">
                <param name="enumClass">server_2026_b.server.utils.UserType</param>
                <param name="useNamed">true</param>
            </type>
        </property>
        <property name="deletedAt"           column="deleted_at"             type="java.time.LocalDateTime"/>
        <property name="deletedByEmployerId" column="deleted_by_employer_id" type="long"/>
    </class>

    <class name="server_2026_b.server.entities.Application" table="applications">
        <id name="id" column="id" type="java.lang.Long">
            <generator class="identity"/>
        </id>
        <property name="employeeId" column="employee_id" type="java.lang.Long" not-null="true"/>
        <property name="employerId" column="employer_id" type="java.lang.Long" not-null="true"/>
        <property name="date" column="date" type="timestamp"/>
        <property name="reason" column="reason">
            <type name="org.hibernate.type.EnumType">
                <param name="enumClass">server_2026_b.server.utils.AbsenceReason</param>
                <param name="useNamed">true</param>
            </type>
        </property>
        <property name="status" column="status" not-null="true">
            <type name="org.hibernate.type.EnumType">
                <param name="enumClass">server_2026_b.server.utils.ApplicationStatus</param>
                <param name="useNamed">true</param>
            </type>
        </property>
    </class>

    <class name="server_2026_b.server.entities.Shift" table="shifts">
        <id name="id" column="id" type="java.lang.Long">
            <generator class="identity"/>
        </id>
        <property name="userId" column="user_id" type="java.lang.Long" not-null="true"/>
        <property name="startTime" column="start_time" type="timestamp" not-null="true"/>
        <property name="endTime" column="end_time" type="timestamp" not-null="true"/>
        <property name="location" column="location" type="string"/>
        <many-to-one name="workSite"
                     class="server_2026_b.server.entities.WorkingSite"
                     column="worksite_id"
                     not-null="false"/>
        <property name="position" column="position" type="string"/>
    </class>

    <class name="server_2026_b.server.entities.EmployeeConstraint" table="employee_constraints">
        <id name="id" column="id" type="long">
            <generator class="identity"/>
        </id>
        <property name="employeeId" column="employee_id" type="string" not-null="true"/>
        <property name="shiftId" column="shift_id" type="long" not-null="true"/>
        <property name="available" column="available" type="boolean" not-null="true"/>
        <property name="comment" column="comment" type="string"/>
        <property name="date" column="date" type="timestamp" not-null="true"/>
    </class>

</hibernate-mapping>
